{
  "name": "@kanbots/api",
  "version": "0.1.0",
  "description": "Pure handler library and agent supervisor for kanbots (no HTTP server)",
  "license": "MIT",
  "author": "Leonardo Cunha",
  "homepage": "https://github.com/leodavinci1/kanbots#readme",
  "bugs": "https://github.com/leodavinci1/kanbots/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leodavinci1/kanbots.git",
    "directory": "packages/api"
  },
  "keywords": ["kanbots", "handlers", "ipc"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@kanbots/core": "workspace:*",
    "@kanbots/dispatcher": "workspace:*",
    "@kanbots/llm": "workspace:*",
    "@kanbots/local-store": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
