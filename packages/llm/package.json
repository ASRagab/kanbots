{
  "name": "@kanbots/llm",
  "version": "0.1.0",
  "description": "Provider catalogue and CLI adapters for kanbots agents",
  "license": "MIT",
  "author": "Leonardo Cunha",
  "homepage": "https://github.com/leodavinci1/kanbots#readme",
  "bugs": "https://github.com/leodavinci1/kanbots/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leodavinci1/kanbots.git",
    "directory": "packages/llm"
  },
  "keywords": ["kanbots", "llm", "claude-code", "codex-cli"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@kanbots/dispatcher": "workspace:*",
    "@kanbots/local-store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
