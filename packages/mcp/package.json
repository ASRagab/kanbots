{
  "name": "@kanbots/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing kanbots state to model clients",
  "license": "MIT",
  "author": "Leonardo Cunha",
  "homepage": "https://github.com/leodavinci1/kanbots#readme",
  "bugs": "https://github.com/leodavinci1/kanbots/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leodavinci1/kanbots.git",
    "directory": "packages/mcp"
  },
  "keywords": ["kanbots", "mcp", "model-context-protocol"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kanbots-mcp-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
